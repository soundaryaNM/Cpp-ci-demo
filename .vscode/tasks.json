{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure",
      "type": "shell",
      "command": "cmake -B build -DCMAKE_BUILD_TYPE=Debug -DBUILD_TESTS=ON -G Ninja",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake Build",
      "type": "shell",
      "command": "cmake --build build --parallel",
      "group": { "kind": "build", "isDefault": true },
      "dependsOn": "CMake Configure",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "cd build && ctest --output-on-failure",
      "group": { "kind": "test", "isDefault": true },
      "dependsOn": "CMake Build",
      "problemMatcher": []
    },
    {
      "label": "Run Tests with Coverage",
      "type": "shell",
      "command": "cmake -B build-cov -DCMAKE_BUILD_TYPE=Debug -DBUILD_TESTS=ON -DBUILD_COVERAGE=ON -G Ninja && cmake --build build-cov --parallel && cd build-cov && ctest && gcovr --root .. --filter ../src --filter ../include --html-details ../coverage-report/index.html --txt .",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Docker Build",
      "type": "shell",
      "command": "docker build --target runtime -t cpp-calculator:local .",
      "group": "build",
      "problemMatcher": []
    }
  ]
}
