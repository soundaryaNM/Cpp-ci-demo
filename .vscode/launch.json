{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Calculator",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/calculator_app",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "CMake Build",
      "setupCommands": [
        { "text": "-enable-pretty-printing", "ignoreFailures": true }
      ]
    },
    {
      "name": "Run Tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/test_calculator",
      "args": ["--gtest_color=yes"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/build",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "CMake Build"
    }
  ]
}
