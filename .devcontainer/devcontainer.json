{
  "name": "C++ CI Demo Dev Container",
  "build": {
    "dockerfile": "../Dockerfile",
    "target": "builder"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools-extension-pack",
        "ms-azuretools.vscode-docker",
        "hbenl.vscode-test-explorer",
        "matepek.vscode-catch2-test-adapter"
      ],
      "settings": {
        "cmake.configureOnOpen": true
      }
    }
  },
  "postCreateCommand": "cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug -G Ninja && cmake --build build --parallel",
  "remoteUser": "root"
}
